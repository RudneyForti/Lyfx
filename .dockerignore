# Controle de versão
.git
.gitignore

# Dependências (reinstaladas no build)
node_modules
.next

# Ambiente (jamais entra na imagem — injetado em runtime via env_file)
.env
.env.*
!.env.docker.example

# Bancos locais
*.db

# Logs e temporários
*.log
npm-debug.log*

# Docs e metadados (não necessários na imagem)
docs/
*.md
!README.md
# Exceções: o Studio lê estes em runtime (Kanban + aba Documentação),
# então precisam entrar no contexto de build para o COPY do Dockerfile.
!docs/cs-board.json
!DOCUMENTATION.md
