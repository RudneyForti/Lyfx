# .env.docker.example — template de configuração para ambiente Docker completo
#
# GRUPOS DE CONTAINERS:
#   Dev  (lyfx/)              → docker compose -f docker-compose.dev.yml up
#   Prod (lyfx-production/)   → docker compose up -d
#
# VARIÁVEIS NECESSÁRIAS:
#   POSTGRES_PASSWORD  — senha do PostgreSQL (usada pelos containers db-dev / db-prod)
#   DATABASE_URL       — construída com o nome do serviço Docker (db-dev ou db-prod)
#                        NÃO usar localhost nem host.docker.internal neste modo

# Desenvolvimento (lyfx/.env)
DATABASE_URL="postgresql://postgres:SUA_SENHA@db-dev:5432/lyfx_dev"
POSTGRES_PASSWORD="SUA_SENHA"

# Produção (lyfx-production/.env)
# DATABASE_URL="postgresql://postgres:SUA_SENHA@db-prod:5432/lyfx_prod"
# POSTGRES_PASSWORD="SUA_SENHA"

SESSION_SECRET="seu_session_secret_aqui"
ADMIN_SECRET="seu_admin_secret_aqui"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua_api_key_aqui"

# CS-32: Cloudflare Turnstile — CAPTCHA após tentativas excessivas de login
# Obter em: https://dash.cloudflare.com → Turnstile → Add site
# Em dev sem estas chaves: CAPTCHA é bypassed automaticamente (aviso no console)
# Chaves de teste (sempre passam): sitekey=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="sua_turnstile_site_key"
TURNSTILE_SECRET_KEY="sua_turnstile_secret_key"
