# .env.docker.example — template de configuração para ambiente Docker
# ⚠️  Usar host.docker.internal (não localhost) — o container não enxerga
#     o PostgreSQL do host via "localhost"

# Desenvolvimento (lyfx/ → docker-compose.dev.yml → porta 3000)
DATABASE_URL="postgresql://postgres:SUA_SENHA@host.docker.internal:5432/lyfx_dev"

# Produção (lyfx-production/ → docker-compose.yml → porta 4000)
# DATABASE_URL="postgresql://postgres:SUA_SENHA@host.docker.internal:5432/lyfx_prod"

SESSION_SECRET="seu_secret_aqui"
ADMIN_SECRET="seu_admin_secret_aqui"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua_api_key_aqui"
