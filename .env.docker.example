# .env.docker.example — copiar para .env ao usar Docker
# ⚠️  Diferença crítica: trocar "localhost" por "host.docker.internal"
#     O container não enxerga o PostgreSQL do host via "localhost"

# Desenvolvimento
DATABASE_URL="postgresql://postgres:SUA_SENHA@host.docker.internal:5432/lyfx_dev"

# Produção (usar no lyfx-production/.env)
# DATABASE_URL="postgresql://postgres:SUA_SENHA@host.docker.internal:5432/lyfx_prod"

SESSION_SECRET="seu_secret_aqui"
ADMIN_SECRET="seu_admin_secret_aqui"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="sua_api_key_aqui"
