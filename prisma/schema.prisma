generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id        String    @id @default(cuid())
  userId    String
  name      String
  type      String    @default("bank") // bank | fintech | broker | other
  color     String    @default("#22D3EE")
  icon      String    @default("building-bank")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id            String      @id @default(cuid())
  userId        String
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  type          String      @default("checking") // checking | savings | credit_card | investment | wallet | other
  balance       Float       @default(0)
  limit         Float?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id               String           @id @default(cuid())
  userId           String           @default("")
  accountId        String?
  date             DateTime
  description      String
  amount           Float
  type             String
  category         String
  subcategory      String?
  notes            String?
  recurrence         String           @default("once")
  recurrenceEndsAt   DateTime?
  installmentGroupId String?          // UUID shared by every installment in the group
  installmentNumber  Int?             // 1-based: which installment this is
  installmentTotal   Int?             // total number of installments in the group
  context            String?
  reimbursable     Boolean          @default(false)
  reimbursedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tags             TransactionTag[]
  // [CS-30] Explicit FK: reimbursement period linked to this transaction
  kmPeriod         KmPeriod?

  @@index([userId, date])           // dominant query: monthly statement/DRE
  @@index([userId, category, date]) // budgets, alerts and reports by category
  @@index([installmentGroupId])     // installment group operations
}

model Goal {
  id            String        @id @default(cuid())
  userId        String        @default("")
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float         @default(0)
  deadline      DateTime
  color         String        @default("#22D3EE")
  icon          String        @default("target")
  status        String        @default("active")
  monthlyAmount Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      GoalPayment[]
}

model GoalPayment {
  id        String    @id @default(cuid())
  goalId    String
  dueDate   DateTime
  amount    Float
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Tag {
  id           String           @id @default(cuid())
  userId       String           @default("")
  name         String
  color        String           @default("#22D3EE")
  icon         String           @default("tag")
  createdAt    DateTime         @default(now())
  transactions TransactionTag[]

  @@unique([userId, name])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String   @default("")
  category  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

model Asset {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          String         @default("real_estate") // real_estate | vehicle | other
  // Real estate
  propertyAddress String?
  // Vehicle
  make          String?
  model         String?
  year          Int?
  plate         String?
  // Common
  purchaseValue Float?
  currentValue  Float?
  purchaseDate  DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      AssetExpense[]
}

model AssetExpense {
  id        String    @id @default(cuid())
  userId    String
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name      String
  type      String    @default("other") // iptu | ipva | itr | dpvat | seguro | licenciamento | manutencao | other
  amount    Float
  dueDate   DateTime?
  paid      Boolean   @default(false)
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Plan {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String       @default("#22D3EE")
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  modules     PlanModule[]
  users       User[]
}

model PlanModule {
  planId  String
  module  String
  plan    Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, module])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String
  avatar    String?
  age         Int?
  gender      String?
  city         String?
  state        String?
  zipCode      String?
  street       String?
  streetNumber String?
  country      String?
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])
  lastSeenAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CS-37a: 2FA TOTP
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String?  // JSON: string[] of bcrypt hashes
}

model Liability {
  id             String   @id @default(cuid())
  userId         String   @default("")
  name           String
  type           String   // cheque_especial | rotativo | emprestimo | financiamento | outro
  currentBalance Float    // current outstanding balance (positive = amount owed)
  interestRate   Float    @default(0)   // % per month
  minimumPayment Float    @default(0)   // minimum monthly installment
  institutionId  String?
  creditor       String?
  notes          String?
  status         String   @default("active") // active | paid_off
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PillProgress {
  id               String   @id @default(cuid())
  userId           String
  pillId           String
  profile          String
  completedAt      DateTime @default(now())
  timeSpentSeconds Int      @default(0)
  quizCorrect      Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([userId, pillId])
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @default("") @unique
  expectedMonthlyIncome Float    @default(0)
  reserveBalance        Float    @default(0)  // real reserve fund balance declared by the user
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Global application config — key/value store managed via Studio
model AppConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// CS-76: Roadmap local layer — the editable, pre-PR side of the Studio board.
// Only cards that have NOT yet entered git own a row here (Backlog / Blocked /
// In Progress). Once a card's CS appears in an open PR or in main, GitHub owns
// its column and the card is locked; the row is kept only so its checklist and
// comments can be spliced back onto the (read-only) approved card by csNumber.
model RoadmapCard {
  id          String    @id @default(cuid())
  csNumber    String    @unique          // "CS-77" — join key against the git board
  title       String
  description String    @db.Text
  columnId    String    @default("backlog") // backlog | blocked | in-progress
  labels      String[]
  order       Int       @default(0)
  startedAt   DateTime?
  dueAt       DateTime?
  checklist   Json      @default("[]")   // KanbanChecklistItem[]
  comments    Json      @default("[]")   // KanbanComment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// CS-18: Notification center
model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String    @default("info")  // info | warning | danger | success
  link        String?
  readAt      DateTime?
  fingerprint String?   // automatic alert dedup (= source alert.id)
  broadcastId String?   // groups manual notifications sent in the same Studio batch
  expiresAt   DateTime? // TTL — danger alerts: createdAt + 7d
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, readAt])
  @@index([broadcastId])
}

// ── CS-17: Reembolso Especial ─────────────────────────────────────────────────

model KmConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  gasolineRate Float    @default(0.25)  // 25% of the price/liter per km
  ethanolRate  Float    @default(0.36)  // 36% of the price/liter per km
  minFuelPct   Float    @default(0.15)  // minimum 15% in receipts vs. amount
  paymentDays  Int      @default(5)     // D+5 business days
  vehiclePlate String   @default("")    // vehicle plate
  vehicleType  String   @default("Carro") // ex: Carro
  vehicleBrand String   @default("")    // ex: Toyota, Honda
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model KmPeriod {
  id            String       @id @default(cuid())
  userId        String
  name          String
  startDate     DateTime
  endDate       DateTime
  fuelType      String       @default("gasoline") // gasoline | ethanol
  status        String       @default("open")     // open | submitted
  submittedAt   DateTime?
  expectedPayAt DateTime?
  totalKm       Float        @default(0)
  fuelPriceAvg  Float        @default(0)
  ratePerKm     Float        @default(0)
  kmAmount      Float        @default(0)
  extraAmount   Float        @default(0)
  grandTotal    Float        @default(0)
  notes         String?
  // [CS-30] Explicit FK to Transaction (used to be a loose field with no declared relation)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  routes        KmRoute[]
  receipts      KmReceipt[]
  expenses      KmExpense[]

  @@index([userId])
}

model KmRoute {
  id          String   @id @default(cuid())
  userId      String
  periodId    String
  period      KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  date        DateTime
  origin      String
  destination String
  km            Float
  routePolyline String?  // overview_polyline codificado — sempre preenchido via mapa
  notes         String?
  placeId       String?  // ref to KmPlace (null = manual entry)
  direction     String?  // "going" | "return" (when placeId is set)
  createdAt     DateTime @default(now())
}

model KmReceipt {
  id          String   @id @default(cuid())
  userId      String
  periodId    String
  period      KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  date        DateTime
  fuelType    String   @default("gasoline")
  liters      Float
  totalAmount Float
  notes       String?
  createdAt   DateTime @default(now())
}

model KmExpense {
  id        String   @id @default(cuid())
  userId    String
  periodId  String
  period    KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  type      String   @default("toll") // toll | parking | accommodation | food | taxi | other
  date      DateTime
  amount    Float
  notes     String?
  createdAt DateTime @default(now())
}

model KmPlace {
  id                 String   @id @default(cuid())
  userId             String
  name               String   // Ex: "Empresa XYZ"
  originAddress      String   @default("")  // starting address (e.g. home/office)
  destinationAddress String   @default("")  // destination address (e.g. company)
  kmGoing            Float    @default(0)   // km ida
  kmReturn           Float    @default(0)   // km volta
  routeGoing         Json?                  // DirectionsResult serializado — rota de ida
  routeReturn        Json?                  // DirectionsResult serializado — rota de volta
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// CS-36: OAuth accounts linked to the user (Google, Microsoft)
model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // "google" | "microsoft"
  providerUserId String   // sub (Google) ou oid (Microsoft)
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId]) // a provider+id pair can only belong to one account
  @@index([userId])
}

// CS-34: Stateful sessions — enables server-side invalidation and an active-sessions view
model Session {
  id          String   @id @default(cuid()) // sessionId armazenado no cookie
  userId      String
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime

  @@index([userId])
  @@index([expiresAt]) // lazy cleanup of expired sessions
}

// CS-35: Audit log — security event tracking
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // null for anonymous events (failed login with a non-existent email)
  sessionId String?  // null when there is no active session
  action    String   // see lib/audit.ts for the list of actions
  ip        String?
  userAgent String?
  metadata  Json?    // contexto adicional (ex: email tentado, sessionId revogado)
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // main query: user history
  @@index([createdAt])         // limpeza de registros antigos
  @@index([action, createdAt]) // filtragem por tipo de evento
}

// CS-32: Rate limiting — registro de tentativas de login por IP
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  email     String?  // apenas para auditoria; nunca usado para lookup
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, success, createdAt]) // consulta principal: contar falhas por IP na janela
  @@index([createdAt])              // limpeza lazy de registros antigos
}
