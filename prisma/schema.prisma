generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id        String    @id @default(cuid())
  userId    String
  name      String
  type      String    @default("bank") // bank | fintech | broker | other
  color     String    @default("#22D3EE")
  icon      String    @default("building-bank")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id            String      @id @default(cuid())
  userId        String
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  type          String      @default("checking") // checking | savings | credit_card | investment | wallet | other
  balance       Float       @default(0)
  limit         Float?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id               String           @id @default(cuid())
  userId           String           @default("")
  accountId        String?
  date             DateTime
  description      String
  amount           Float
  type             String
  category         String
  subcategory      String?
  notes            String?
  recurrence         String           @default("once")
  recurrenceEndsAt   DateTime?
  installmentGroupId String?          // UUID compartilhado entre todas as parcelas do grupo
  installmentNumber  Int?             // 1-based: qual parcela é esta
  installmentTotal   Int?             // total de parcelas do grupo
  context            String?
  reimbursable     Boolean          @default(false)
  reimbursedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tags             TransactionTag[]
  // [CS-30] FK explícita: período de reembolso vinculado a esta transação
  kmPeriod         KmPeriod?

  @@index([userId, date])           // consulta dominante: extrato/DRE do mês
  @@index([userId, category, date]) // orçamentos, alertas e relatórios por categoria
  @@index([installmentGroupId])     // operações em grupo de parcelas
}

model Goal {
  id            String        @id @default(cuid())
  userId        String        @default("")
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float         @default(0)
  deadline      DateTime
  color         String        @default("#22D3EE")
  icon          String        @default("target")
  status        String        @default("active")
  monthlyAmount Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      GoalPayment[]
}

model GoalPayment {
  id        String    @id @default(cuid())
  goalId    String
  dueDate   DateTime
  amount    Float
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Tag {
  id           String           @id @default(cuid())
  userId       String           @default("")
  name         String
  color        String           @default("#22D3EE")
  icon         String           @default("tag")
  createdAt    DateTime         @default(now())
  transactions TransactionTag[]

  @@unique([userId, name])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String   @default("")
  category  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

model Asset {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          String         @default("real_estate") // real_estate | vehicle | other
  // Imóvel
  propertyAddress String?
  // Veículo
  make          String?
  model         String?
  year          Int?
  plate         String?
  // Comum
  purchaseValue Float?
  currentValue  Float?
  purchaseDate  DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      AssetExpense[]
}

model AssetExpense {
  id        String    @id @default(cuid())
  userId    String
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name      String
  type      String    @default("other") // iptu | ipva | itr | dpvat | seguro | licenciamento | manutencao | other
  amount    Float
  dueDate   DateTime?
  paid      Boolean   @default(false)
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Plan {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String       @default("#22D3EE")
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  modules     PlanModule[]
  users       User[]
}

model PlanModule {
  planId  String
  module  String
  plan    Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([planId, module])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String
  avatar    String?
  age         Int?
  gender      String?
  city         String?
  state        String?
  zipCode      String?
  street       String?
  streetNumber String?
  country      String?
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id])
  lastSeenAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CS-37a: 2FA TOTP
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String?  // JSON: string[] de hashes bcrypt
}

model Liability {
  id             String   @id @default(cuid())
  userId         String   @default("")
  name           String
  type           String   // cheque_especial | rotativo | emprestimo | financiamento | outro
  currentBalance Float    // saldo devedor atual (positivo = quanto deve)
  interestRate   Float    @default(0)   // % ao mês
  minimumPayment Float    @default(0)   // parcela mínima mensal
  institutionId  String?
  creditor       String?
  notes          String?
  status         String   @default("active") // active | paid_off
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PillProgress {
  id               String   @id @default(cuid())
  userId           String
  pillId           String
  profile          String
  completedAt      DateTime @default(now())
  timeSpentSeconds Int      @default(0)
  quizCorrect      Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([userId, pillId])
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @default("") @unique
  expectedMonthlyIncome Float    @default(0)
  reserveBalance        Float    @default(0)  // saldo real do fundo de reserva declarado pelo usuário
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Global application config — key/value store managed via Studio
model AppConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// CS-18: Central de notificações
model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String    @default("info")  // info | warning | danger | success
  link        String?
  readAt      DateTime?
  fingerprint String?   // dedup de alertas automáticos (= alert.id da origem)
  broadcastId String?   // agrupa notificações manuais enviadas no mesmo lote pelo Studio
  expiresAt   DateTime? // TTL — danger alerts: createdAt + 7d
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, readAt])
  @@index([broadcastId])
}

// ── CS-17: Reembolso Especial ─────────────────────────────────────────────────

model KmConfig {
  id           String   @id @default(cuid())
  userId       String   @unique
  gasolineRate Float    @default(0.25)  // 25% do preço/litro por km
  ethanolRate  Float    @default(0.36)  // 36% do preço/litro por km
  minFuelPct   Float    @default(0.15)  // mínimo 15% em notas vs. montante
  paymentDays  Int      @default(5)     // D+5 dias úteis
  vehiclePlate String   @default("")    // placa do veículo
  vehicleType  String   @default("Carro") // ex: Carro
  vehicleBrand String   @default("")    // ex: Toyota, Honda
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model KmPeriod {
  id            String       @id @default(cuid())
  userId        String
  name          String
  startDate     DateTime
  endDate       DateTime
  fuelType      String       @default("gasoline") // gasoline | ethanol
  status        String       @default("open")     // open | submitted
  submittedAt   DateTime?
  expectedPayAt DateTime?
  totalKm       Float        @default(0)
  fuelPriceAvg  Float        @default(0)
  ratePerKm     Float        @default(0)
  kmAmount      Float        @default(0)
  extraAmount   Float        @default(0)
  grandTotal    Float        @default(0)
  notes         String?
  // [CS-30] FK explícita para Transaction (era campo solto sem relação declarada)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  routes        KmRoute[]
  receipts      KmReceipt[]
  expenses      KmExpense[]

  @@index([userId])
}

model KmRoute {
  id          String   @id @default(cuid())
  userId      String
  periodId    String
  period      KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  date        DateTime
  origin      String
  destination String
  km            Float
  routePolyline String?  // overview_polyline codificado — sempre preenchido via mapa
  notes         String?
  placeId       String?  // ref to KmPlace (null = manual entry)
  direction     String?  // "going" | "return" (when placeId is set)
  createdAt     DateTime @default(now())
}

model KmReceipt {
  id          String   @id @default(cuid())
  userId      String
  periodId    String
  period      KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  date        DateTime
  fuelType    String   @default("gasoline")
  liters      Float
  totalAmount Float
  notes       String?
  createdAt   DateTime @default(now())
}

model KmExpense {
  id        String   @id @default(cuid())
  userId    String
  periodId  String
  period    KmPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  type      String   @default("toll") // toll | parking | accommodation | food | taxi | other
  date      DateTime
  amount    Float
  notes     String?
  createdAt DateTime @default(now())
}

model KmPlace {
  id                 String   @id @default(cuid())
  userId             String
  name               String   // Ex: "Empresa XYZ"
  originAddress      String   @default("")  // endereço de partida (ex: casa/escritório)
  destinationAddress String   @default("")  // endereço de destino (ex: empresa)
  kmGoing            Float    @default(0)   // km ida
  kmReturn           Float    @default(0)   // km volta
  routeGoing         Json?                  // DirectionsResult serializado — rota de ida
  routeReturn        Json?                  // DirectionsResult serializado — rota de volta
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// CS-36: Contas OAuth vinculadas ao usuário (Google, Microsoft)
model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // "google" | "microsoft"
  providerUserId String   // sub (Google) ou oid (Microsoft)
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId]) // um provedor+id só pode estar em uma conta
  @@index([userId])
}

// CS-34: Sessões com estado — permite invalidação server-side e view de sessões ativas
model Session {
  id          String   @id @default(cuid()) // sessionId armazenado no cookie
  userId      String
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime

  @@index([userId])
  @@index([expiresAt]) // limpeza lazy de sessões expiradas
}

// CS-35: Audit log — registro de eventos de segurança
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // null para eventos anônimos (login falho com email inexistente)
  sessionId String?  // null quando não há sessão ativa
  action    String   // ver lib/audit.ts para lista de ações
  ip        String?
  userAgent String?
  metadata  Json?    // contexto adicional (ex: email tentado, sessionId revogado)
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // consulta principal: histórico do usuário
  @@index([createdAt])         // limpeza de registros antigos
  @@index([action, createdAt]) // filtragem por tipo de evento
}

// CS-32: Rate limiting — registro de tentativas de login por IP
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  email     String?  // apenas para auditoria; nunca usado para lookup
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, success, createdAt]) // consulta principal: contar falhas por IP na janela
  @@index([createdAt])              // limpeza lazy de registros antigos
}
