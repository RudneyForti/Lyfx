generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id        String    @id @default(cuid())
  userId    String
  name      String
  type      String    @default("bank") // bank | fintech | broker | other
  color     String    @default("#22D3EE")
  icon      String    @default("building-bank")
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
}

model Account {
  id            String      @id @default(cuid())
  userId        String
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  type          String      @default("checking") // checking | savings | credit_card | investment | wallet | other
  balance       Float       @default(0)
  limit         Float?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transaction {
  id               String           @id @default(cuid())
  userId           String           @default("")
  accountId        String?
  date             DateTime
  description      String
  amount           Float
  type             String
  category         String
  subcategory      String?
  notes            String?
  recurrence         String           @default("once")
  recurrenceEndsAt   DateTime?
  installmentGroupId String?          // UUID compartilhado entre todas as parcelas do grupo
  installmentNumber  Int?             // 1-based: qual parcela é esta
  installmentTotal   Int?             // total de parcelas do grupo
  context            String?
  reimbursable     Boolean          @default(false)
  reimbursedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  tags             TransactionTag[]
}

model Goal {
  id            String        @id @default(cuid())
  userId        String        @default("")
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float         @default(0)
  deadline      DateTime
  color         String        @default("#22D3EE")
  icon          String        @default("target")
  status        String        @default("active")
  monthlyAmount Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      GoalPayment[]
}

model GoalPayment {
  id        String    @id @default(cuid())
  goalId    String
  dueDate   DateTime
  amount    Float
  paid      Boolean   @default(false)
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Tag {
  id           String           @id @default(cuid())
  userId       String           @default("")
  name         String
  color        String           @default("#22D3EE")
  icon         String           @default("tag")
  createdAt    DateTime         @default(now())
  transactions TransactionTag[]

  @@unique([userId, name])
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String   @default("")
  category  String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
}

model Asset {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          String         @default("real_estate") // real_estate | vehicle | other
  // Imóvel
  propertyAddress String?
  // Veículo
  make          String?
  model         String?
  year          Int?
  plate         String?
  // Comum
  purchaseValue Float?
  currentValue  Float?
  purchaseDate  DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      AssetExpense[]
}

model AssetExpense {
  id        String    @id @default(cuid())
  userId    String
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name      String
  type      String    @default("other") // iptu | ipva | itr | dpvat | seguro | licenciamento | manutencao | other
  amount    Float
  dueDate   DateTime?
  paid      Boolean   @default(false)
  paidAt    DateTime?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?  @unique
  password  String
  avatar    String?
  age         Int?
  gender      String?
  city         String?
  state        String?
  zipCode      String?
  street       String?
  streetNumber String?
  country      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Liability {
  id             String   @id @default(cuid())
  userId         String   @default("")
  name           String
  type           String   // cheque_especial | rotativo | emprestimo | financiamento | outro
  currentBalance Float    // saldo devedor atual (positivo = quanto deve)
  interestRate   Float    @default(0)   // % ao mês
  minimumPayment Float    @default(0)   // parcela mínima mensal
  institutionId  String?
  creditor       String?
  notes          String?
  status         String   @default("active") // active | paid_off
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PillProgress {
  id               String   @id @default(cuid())
  userId           String
  pillId           String
  profile          String
  completedAt      DateTime @default(now())
  timeSpentSeconds Int      @default(0)
  quizCorrect      Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([userId, pillId])
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @default("") @unique
  expectedMonthlyIncome Float    @default(0)
  reserveBalance        Float    @default(0)  // saldo real do fundo de reserva declarado pelo usuário
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
